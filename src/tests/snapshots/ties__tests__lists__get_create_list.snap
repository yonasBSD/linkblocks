<div class="px-4 py-4 bg-neutral-900"><form action="/search" method="get" hx-boost="true" class="inline-flex w-full"><input type="text" name="q" placeholder="Search all bookmarks" value="" class="leading-8 px-3 bg-neutral-900 grow border rounded-l border-neutral-700 max-w-2xl" /><button class="px-2 text-neutral-400 shrink border-y border-r rounded-r border-neutral-700">Search</button></form></div><div class="border-t border-black"><div class="border-t border-neutral-700"></div><form action="/lists/create" method="POST" class="flex flex-col max-w-xl mx-4 mb-4 grow"><header class="mt-3 mb-4"><h1 class="text-xl font-bold">Create a list</h1></header><label for="title">Title</label><input required="" name="title" type="text" value="" class="rounded py-1.5 px-3 mt-2 bg-neutral-900" /><label class="mt-4">Note<textarea name="content" placeholder="" value="" class="rounded py-1.5 px-3 mt-2 bg-neutral-900 block w-full"></textarea></label><div class="mt-3 mb-5"><label><input type="checkbox" name="private" value="true" /> Private</label></div><button type="submit" class="bg-neutral-300 py-1.5 px-3 text-neutral-900 rounded mt-4 self-end">Add List</button></form></div>
